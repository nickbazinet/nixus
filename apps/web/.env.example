# Public site URL (used for OG tags, sitemap.xml — Story 4.x)
VITE_SITE_URL=https://nixus.nicolasbazinet.net

# Cloudflare Web Analytics token (Story 4.1).
# Public site identifier — NOT a secret. Get one from the Cloudflare
# dashboard for the site's domain. Leave unset in dev: the beacon is only
# injected on production builds when this is set, so dev/test runs stay
# offline and cookieless.
VITE_CLOUDFLARE_ANALYTICS_TOKEN=

# Optional GitHub token for the build-time releases fetcher (Story 2.1) to
# avoid unauthenticated rate limits on CI. Public repo, so unauth works too.
# GITHUB_TOKEN=
